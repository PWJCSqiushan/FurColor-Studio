FURCOLOR_MODE=local
FURCOLOR_HOST=127.0.0.1
FURCOLOR_PORT=8899
FURCOLOR_DATA_DIR=./runtime
FURCOLOR_ENGINE_ROOT=./engine
# 必须改成操作者实际允许 FurColor 访问的照片根目录；多个目录用英文分号分隔。
FURCOLOR_ALLOWED_ROOTS=D:\Photos;E:\Photography
# Optional Fursee V4 subject intelligence. Keep weights outside the repository.
FURCOLOR_FURSEE_MODEL_DIR=D:\Models\fursee_models
FURCOLOR_FURSEE_PYTHON=.\.venv-fursee\Scripts\python.exe